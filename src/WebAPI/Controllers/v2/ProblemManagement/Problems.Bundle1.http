### Create problem draft
POST {{host}}/api/v2/problems/drafts
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Two Sum Basic",
  "slug": "two-sum-basic",
  "timeLimitMs": 1000,
  "memoryLimitKb": 262144,
  "typeCode": "algorithm",
  "scoringCode": "icpc",
  "visibilityCode": "private",
  "descriptionMd": "# Two Sum\n\nGiven an array of integers..."
}

### Get problem detail
GET {{host}}/api/v2/problems/{{problemId}}
Authorization: Bearer {{token}}

### Update content
PUT {{host}}/api/v2/problems/{{problemId}}/content
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Two Sum Basic Updated",
  "slug": "two-sum-basic",
  "timeLimitMs": 1500,
  "memoryLimitKb": 262144,
  "typeCode": "algorithm",
  "scoringCode": "icpc",
  "visibilityCode": "private",
  "descriptionMd": "# Two Sum\n\n## Statement\nFind two numbers..."
}

### Set difficulty
PUT {{host}}/api/v2/problems/{{problemId}}/difficulty
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "difficulty": "easy"
}

### Replace tags
PUT {{host}}/api/problems/{{problemId}}/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tagIds": [
    "11111111-1111-1111-1111-111111111111",
    "22222222-2222-2222-2222-222222222222"
  ]
}