### 4) GET PROBLEM DETAIL
GET {{baseUrl}}/api/v{{apiVersion}}/Problems/{{problemId}}
Authorization: Bearer {{authToken}}

### 5) UPDATE PROBLEM - markdown mode
PUT {{baseUrl}}/api/v{{apiVersion}}/Problems/{{problemId}}/content
Authorization: Bearer {{authToken}}
Content-Type: multipart/form-data; boundary=UpdateProblemBoundary

--UpdateProblemBoundary
Content-Disposition: form-data; name="Title"

Two Sum Updated
--UpdateProblemBoundary
Content-Disposition: form-data; name="Slug"

binary-search-donation-updated
--UpdateProblemBoundary
Content-Disposition: form-data; name="Difficulty"

easy
--UpdateProblemBoundary
Content-Disposition: form-data; name="TypeCode"

algorithm
--UpdateProblemBoundary
Content-Disposition: form-data; name="ScoringCode"

acm
--UpdateProblemBoundary
Content-Disposition: form-data; name="TimeLimitMs"

1500
--UpdateProblemBoundary
Content-Disposition: form-data; name="MemoryLimitKb"

262144
--UpdateProblemBoundary
Content-Disposition: form-data; name="DescriptionMd"

Updated description for Two Sum problem.
--UpdateProblemBoundary
Content-Disposition: form-data; name="ProblemMode"

pro
--UpdateProblemBoundary
Content-Disposition: form-data; name="TagIds"

{{tagId1}}
--UpdateProblemBoundary--

### 6) GET ALL PUBLIC PROBLEMS
GET {{baseUrl}}/api/v{{apiVersion}}/Problems/public?page=1&pageSize=10&search=two&difficulty=easy

### 7) CREATE PROBLEM TEMPLATE
POST {{baseUrl}}/api/v{{apiVersion}}/ProblemTemplates/{{problemId}}/templates
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "runtimeId": "{{runtimeId}}",
  "templateCode": "#include <bits/stdc++.h>\\nusing namespace std;\\n\\nclass Solution {\\npublic:\\n    int solve(vector<int>& a) {\\n        __USER_CODE__\\n    }\\n};",
  "injectionPoint": "âsjdnsa",
  "solutionSignature": "int solve(vector<int>& a)",
  "version": 1
}

### 8) GET PROBLEM TEMPLATES
GET {{baseUrl}}/api/v{{apiVersion}}/ProblemTemplates/{{problemId}}/templates

###
PUT {{baseUrl}}/api/v{{apiVersion}}/ProblemTemplates/templates/{{codeTemplateId}}
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "templateCode": "#include <bits/stdc++.h>\\nusing namespace std;\\n\\nclass Solution {\\npublic:\\n    int solve(vector<int>& a) {\\n        __USER_CODE__\\n    }\\n};\\n// updated",
  "injectionPoint": "__USER_CODEzzzzzzzzzz_-",
  "solutionSignature": "int solve(vector<int>& a)",
  "isActive": true
}
### 10) DELETE PROBLEM TEMPLATE (soft delete)
DELETE {{baseUrl}}/api/v{{apiVersion}}/ProblemTemplates/templates/{{codeTemplateId}}
Authorization: Bearer {{authToken}}

### 11) GET PROBLEM BANKS
GET {{baseUrl}}/api/v{{apiVersion}}/Problems/banks?page=1&pageSize=10&search=binary&difficulty=easy
Authorization: Bearer {{authToken}}

### 12) CREATE VIRTUAL PROBLEM - JSON
POST {{baseUrl}}/api/v{{apiVersion}}/Problems/virtual
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "originProblemId": "{{originProblemId}}",
  "slug": "two-sum-basic-virtual-custom",
  "title": "Two Sum Basic Virtual",
  "visibilityCode": "private"
}

### 13) CREATE VIRTUAL PROBLEM - auto generate slug
POST {{baseUrl}}/api/v{{apiVersion}}/Problems/virtual
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "originProblemSlug": "two-sum-basic",
  "title": "Two Sum Basic Virtual Auto",
  "visibilityCode": "private"
}

