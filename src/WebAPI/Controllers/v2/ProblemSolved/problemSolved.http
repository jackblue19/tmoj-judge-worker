@baseUrl = https://localhost:7210
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..X-tusXvFc6ly0hboSUdrEOgOM2-0mzy_DZixePfnnEM


### Get all solved problems count
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats
Authorization: Bearer {{authToken}}

### Get solved public problems
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?visibilityCode=public
Authorization: Bearer {{authToken}}

### Get solved in-class visibility problems
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?visibilityCode=in-class
Authorization: Bearer {{authToken}}

### Get solved in-bank problems
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?visibilityCode=in-bank
Authorization: Bearer {{authToken}}

### Get solved by contest source
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?solvedSourceCode=contest
Authorization: Bearer {{authToken}}

### Get solved by class source
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?solvedSourceCode=in-class
Authorization: Bearer {{authToken}}

### Get solved public problems through contest
GET {{baseUrl}}/api/v2/ProblemSolved/me/stats?visibilityCode=public&solvedSourceCode=contest
Authorization: Bearer {{authToken}}

### list problem solved

### List all solved problems
GET {{baseUrl}}/api/v2/ProblemSolved/me?page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved public problems
GET {{baseUrl}}/api/v2/ProblemSolved/me?visibilityCode=public&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved in-class visibility problems
GET {{baseUrl}}/api/v2/ProblemSolved/me?visibilityCode=in-class&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved in-bank problems
GET {{baseUrl}}/api/v2/ProblemSolved/me?visibilityCode=in-bank&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved by contest source
GET {{baseUrl}}/api/v2/ProblemSolved/me?solvedSourceCode=contest&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved by class source
GET {{baseUrl}}/api/v2/ProblemSolved/me?solvedSourceCode=in-class&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved by practice source
GET {{baseUrl}}/api/v2/ProblemSolved/me?solvedSourceCode=practice&page=1&pageSize=20
Authorization: Bearer {{authToken}}

### List solved public problems in contest
GET {{baseUrl}}/api/v2/ProblemSolved/me?visibilityCode=public&solvedSourceCode=contest&page=1&pageSize=20
Authorization: Bearer {{authToken}}