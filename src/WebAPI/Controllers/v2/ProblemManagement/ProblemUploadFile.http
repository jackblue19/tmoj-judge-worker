### Get problem detail
GET {{host}}/api/v2/problems/{{problemId}}
Authorization: Bearer {{token}}

###
GET {{host}}/api/v2/problems/{{problemId}}/statement
Authorization: Bearer {{token}}

### Update content
PUT {{host}}/api/v2/problems/{{problemId}}/content
Authorization: Bearer {{token}}
Content-Type: application/json
{
  "title": "Two Sum Basic Updated into v3",
  "slug": "two-sum-basic-v3",
  "timeLimitMs": 1500,
  "memoryLimitKb": 262144,
  "typeCode": "algorithm",
  "scoringCode": "icpc",
  "visibilityCode": "private",
  "descriptionMd": "Two Sum\n\nStatement\nFind two numbers..."
}

### Create tag 1
POST {{host}}/api/v2/problems/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Dynamic Programming v3",
  "slug": "dynamic-programming-v3"
}

### Create tag 2
POST {{host}}/api/v2/problems/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Two Pointers v3",
  "slug": "two-pointers-v3"
}


### Set difficulty
PUT {{host}}/api/v2/problems/{{problemId}}/difficulty
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "difficulty": "hard"
}

### Attach tags
POST {{host}}/api/v2/problems/{{problemId}}/tags/attach
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tagIds": [
    "{{tagId2}}",
    "{{tagId1}}"
  ]
}

### Replace tags  ( >= 1 Ok)
PUT {{host}}/api/v2/problems/{{problemId}}/tags
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tagIds": [
    "{{tagId1}}"
  ]
}

###
PUT {{host}}/api/v2/problems/{{problemId}}/content
Authorization: Bearer {{token}}
Content-Type: multipart/form-data

title=Updated Title
StatementFile=@new.pdf